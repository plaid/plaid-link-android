<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <application
    android:name=".LinkSampleApplication"
    android:allowBackup="true"
    android:icon="@drawable/plaid_icon"
    android:label="@string/app_name"
    android:supportsRtl="true"
    android:theme="@style/AppTheme">
    <activity
      android:name=".MainActivity"
      android:exported="true"
      android:label="@string/app_name"
      android:theme="@style/AppTheme">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

    <!-- One Activity per flow, so each can register its own result launcher in onCreate. -->
    <activity android:name=".StandardLinkActivity" android:exported="false" android:theme="@style/AppTheme" />
    <activity android:name=".HeadlessActivity" android:exported="false" android:theme="@style/AppTheme" />
    <activity android:name=".LayerActivity" android:exported="false" android:theme="@style/AppTheme" />
    <activity android:name=".EmbeddedActivity" android:exported="false" android:theme="@style/AppTheme" />
  </application>

</manifest>
